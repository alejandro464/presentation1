// loop through a vector 
fn main(){
    let nums = vec![10, 20, 30]; //creates the vector

    for n in nums {
        println!("numbers {}", n);
    }
}
//while loop 1 decreasing
fn main(){
    let mut count = 10; //mutable variable
     while count > 0 {
        println!("{}", count);
        count -= 1; //decreases count
     }
}
//while loop 2 incrementing
fn main(){
    let mut count = 1;
    while count =< 10{
    println!("{}", count);
    count += 1;
    }
}
//infinite loop + break
fn main(){
    let mut x = 0;
    loop {  //infinite loop
        x += 1;

        if x == 5 {
            println!("reached 5");
            break; //exit loop
        }
    } 
}
//reverse string 
fn main(){
    let x = "Alejandro";

    //chars() iterates characters
    //rev() reverse them
    //collect() turn back into string
    let reversed: String = x.chars().rev().collect();

    println!("{}",x);
    println!("{}",reversed);
}
