//basic math
fn main() {
    let a = 10; //immutable variable
    let b = 5;
    //. {} is needed for it to work. its the placeholder
    println!("a + b = {}", a + b); //addition
    println!("{}", a - b); //subtraction
    println!("{}",a * b); // multiplication
    println!("{}", a / b); // division
}
//variables
fn main() {
    let x = 5; // immutable 
    let mut y = 10; // mutable means that you can update as many times that you want
    //such as..
    y = y + 1;

    println!("x = {}", x);
    println!("y = {}", y);
}

//simple function
fn double(x: i32) -> i32 {//parameter x must be a i32-bit signed integer -> means it will return a 32-bit signed integer
    x*2
}
fn main(){
    let result = double(5);
    println!("{}", result)
}

